---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header>
  <a class="nav-name" href={base}>Madlen von Wulffen</a>
  <nav>
    <ul class="nav-links">
      <li><a href={`${base}projects`} class={currentPath.startsWith(`${base}projects`) ? 'active' : ''}>Projects</a></li>
      <li><a href={`${base}thinking-space`} class={currentPath.startsWith(`${base}thinking-space`) ? 'active' : ''}>Thinking Space</a></li>
      <li><a href={`${base}about`} class={currentPath.startsWith(`${base}about`) ? 'active' : ''}>About</a></li>
    </ul>
  </nav>
</header>

<style>
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2.6rem;
    z-index: 200;
    background: var(--bg);
  }

  .nav-name {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    transition: color 0.15s;
  }
  .nav-name:hover { color: var(--red); }

  .nav-links {
    display: flex;
    gap: 2.4rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--red); }
  .nav-links a.active { color: var(--red); }
</style>
