---
const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Projects', href: `${base}` },
  { label: 'Diary',    href: `${base}diary` },
  { label: 'About',    href: `${base}about` },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <a class="site-name" href={base}>Madlen von Wulffen</a>
  <nav>
    <ul class="site-nav">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>