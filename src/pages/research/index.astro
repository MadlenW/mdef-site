---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Research · Madlen von Wulffen" description="A contamination web of questions, research, and theory behind To Home.">

<style>
  :global(body:has(#rp) footer) { display: none; }
  :global(body:has(#rp)) { overflow: hidden; }

  #rp {
    position: fixed;
    inset: 0;
    top: 56px;
    background: #ffffff;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    overflow: hidden;
  }

  #bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 42px;
    background: rgba(255,255,255,0.97);
    border-bottom: 0.5px solid #e0e0e0;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 18px;
    z-index: 50;
  }

  #bar-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #111;
    white-space: nowrap;
    flex-shrink: 0;
  }

  #search {
    width: 170px;
    padding: 4px 10px;
    border: 0.5px solid #ccc;
    border-radius: 2px;
    font-size: 11px;
    font-family: inherit;
    outline: none;
    flex-shrink: 0;
  }
  #search:focus { border-color: #111; }
  #search::placeholder { color: #bbb; }

  .fp {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 9px;
    border: 0.5px solid #ccc;
    border-radius: 2px;
    background: #fff;
    color: #999;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.1s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .fp:hover { color: #111; border-color: #888; }
  .fp.on-past    { background: #8B7355; color: #fff; border-color: #8B7355; }
  .fp.on-present { background: #4A6741; color: #fff; border-color: #4A6741; }
  .fp.on-future  { background: #3D5A80; color: #fff; border-color: #3D5A80; }

  .fsel {
    font-size: 10px;
    padding: 4px 7px;
    border: 0.5px solid #ccc;
    border-radius: 2px;
    font-family: inherit;
    background: #fff;
    color: #555;
    outline: none;
    cursor: pointer;
    flex-shrink: 0;
  }

  #resetbtn {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 9px;
    border: 0.5px solid #e0e0e0;
    border-radius: 2px;
    background: #fff;
    color: #bbb;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.1s;
    flex-shrink: 0;
  }
  #resetbtn:hover { color: #111; border-color: #888; }

  #qcount {
    font-size: 9px;
    color: #bbb;
    letter-spacing: 0.06em;
    margin-left: auto;
    white-space: nowrap;
    flex-shrink: 0;
  }

  #canvas-wrap {
    position: absolute;
    top: 42px; left: 0; right: 0; bottom: 0;
  }

  #canvas {
    width: 100%;
    height: 100%;
    cursor: grab;
    display: block;
  }
  #canvas:active { cursor: grabbing; }

  #legend {
    position: absolute;
    bottom: 18px;
    left: 18px;
    background: rgba(255,255,255,0.97);
    border: 0.5px solid #e0e0e0;
    border-radius: 2px;
    padding: 10px 13px;
    pointer-events: none;
    z-index: 20;
  }
  .lt { font-size: 8px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #bbb; margin-bottom: 7px; }
  .lr { display: flex; align-items: center; gap: 7px; margin-bottom: 5px; font-size: 10px; color: #555; font-weight: 500; }
  .ld { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .lhr { border: none; border-top: 0.5px solid #eee; margin: 7px 0; }

  #loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #bbb;
    z-index: 10;
  }
  .ldots { display: flex; gap: 5px; }
  .ld2 { width: 5px; height: 5px; border-radius: 50%; animation: lp 1.1s ease-in-out infinite; }
  @keyframes lp { 0%,100%{opacity:.2;transform:scale(.7)} 50%{opacity:1;transform:scale(1.2)} }

  #drawer {
    position: absolute;
    top: 0; right: 0;
    width: 360px;
    height: 100%;
    background: #fff;
    border-left: 0.5px solid #e0e0e0;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    z-index: 40;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  #drawer.open { transform: translateX(0); }

  #dh {
    padding: 16px 16px 0;
    flex-shrink: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  #ddeck {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    color: #fff;
    display: inline-block;
  }
  #dclose {
    background: none;
    border: 0.5px solid #e0e0e0;
    border-radius: 50%;
    width: 24px; height: 24px;
    cursor: pointer;
    font-size: 15px;
    color: #999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.1s;
    flex-shrink: 0;
  }
  #dclose:hover { color: #111; border-color: #111; }

  #dbody {
    flex: 1;
    overflow-y: auto;
    padding: 12px 16px 28px;
    scrollbar-width: thin;
    scrollbar-color: #eee transparent;
  }
  #dq {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.55;
    color: #111;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 0.5px solid #ebebeb;
  }
  .ds { margin-bottom: 13px; }
  .dl { font-size: 8px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #bbb; margin-bottom: 6px; }
  .dtags { display: flex; flex-wrap: wrap; gap: 4px; }
  .dtag { font-size: 9px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; padding: 3px 7px; border: 0.5px solid #273859; border-radius: 2px; color: #273859; background: rgba(39,56,89,.04); }
  .dkw { font-size: 9px; color: #999; background: #f5f5f5; padding: 2px 6px; border-radius: 2px; }
  .dhr { border: none; border-top: 0.5px solid #ebebeb; margin: 11px 0; }
  .dmi { font-size: 11px; color: #555; line-height: 1.6; padding: 4px 0; border-bottom: 0.5px solid #f5f5f5; display: flex; align-items: flex-start; gap: 6px; }
  .dmi:last-child { border-bottom: none; }
  .dmb { width: 4px; height: 4px; border-radius: 50%; background: #ccc; flex-shrink: 0; margin-top: 7px; }
  .dti { font-size: 11px; color: #555; line-height: 1.5; padding: 4px 0; border-bottom: 0.5px solid #f5f5f5; font-style: italic; }
  .dti:last-child { border-bottom: none; }
  .dcps { display: flex; flex-wrap: wrap; gap: 4px; }
  .dcp { font-size: 9px; font-weight: 600; letter-spacing: 0.07em; padding: 3px 8px; border-radius: 2px; cursor: pointer; border: 0.5px solid; background: #fff; font-family: inherit; transition: opacity 0.1s; }
  .dcp:hover { opacity: 0.6; }
  .ddesc { font-size: 11px; color: #555; line-height: 1.75; font-style: italic; background: #fafafa; border-left: 2px solid #111; padding: 9px 12px; border-radius: 0 2px 2px 0; }
</style>

<div id="rp">
  <div id="bar">
    <span id="bar-title">To Home — Research Web</span>
    <input type="text" id="search" placeholder="Search questions…" autocomplete="off">
    <button class="fp" data-deck="Past">Past</button>
    <button class="fp" data-deck="Present">Present</button>
    <button class="fp" data-deck="Future">Future</button>
    <select id="dimsel" class="fsel">
      <option value="">All Dimensions</option>
      <option>Territorializing</option>
      <option>Bubbling</option>
      <option>Outboxing</option>
      <option>Connecting</option>
      <option>Sensory Re-evocation</option>
    </select>
    <select id="typesel" class="fsel">
      <option value="">All Research Types</option>
      <option>Autoethnographic</option>
      <option>Embodied Practice</option>
      <option>Speculative Design</option>
      <option>Participatory</option>
      <option>Theoretical</option>
      <option>Desk Research</option>
    </select>
    <button id="resetbtn">× Reset</button>
    <span id="qcount"></span>
  </div>

  <div id="canvas-wrap">
    <div id="loading">
      <div class="ldots">
        <div class="ld2" style="background:#8B7355"></div>
        <div class="ld2" style="background:#4A6741;animation-delay:.18s"></div>
        <div class="ld2" style="background:#3D5A80;animation-delay:.36s"></div>
      </div>
      Building the web…
    </div>
    <svg id="canvas"></svg>
    <div id="legend">
      <div class="lt">Deck</div>
      <div class="lr"><div class="ld" style="background:#8B7355"></div>Past</div>
      <div class="lr"><div class="ld" style="background:#4A6741"></div>Present</div>
      <div class="lr"><div class="ld" style="background:#3D5A80"></div>Future</div>
      <div class="lhr"></div>
      <div style="font-size:9px;color:#bbb;line-height:1.6">Hover — show connections<br>Click — full detail</div>
    </div>
    <div id="drawer">
      <div id="dh">
        <div id="ddeck"></div>
        <button id="dclose">×</button>
      </div>
      <div id="dbody">
        <div id="dq"></div>
        <div class="ds" id="ddescwrap"><div class="dl">Context</div><div id="ddesc" class="ddesc"></div></div>
        <div class="ds"><div class="dl">Boccagni Dimensions</div><div class="dtags" id="dboc"></div></div>
        <div class="ds"><div class="dl">Keywords</div><div class="dtags" id="dkw"></div></div>
        <div class="dhr"></div>
        <div class="ds"><div class="dl">Research Moments</div><div id="dmom"></div></div>
        <div class="ds"><div class="dl">Theoretical Sources</div><div id="dth"></div></div>
        <div class="dhr"></div>
        <div class="ds"><div class="dl">Contaminated by</div><div class="dcps" id="dconn"></div></div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(async () => {
  const Q_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQoJAmUIxX-uvjWWTeWVheKeuaCu-o4KcKfOkc96WS2dGtegyiVfwyBf202tsVJmjNFsj41ooboxMLb/pub?gid=38610428&single=true&output=csv";
  const C_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQoJAmUIxX-uvjWWTeWVheKeuaCu-o4KcKfOkc96WS2dGtegyiVfwyBf202tsVJmjNFsj41ooboxMLb/pub?gid=2026582461&single=true&output=csv";

  const DECK_COLOR = { Past:"#8B7355", Present:"#4A6741", Future:"#3D5A80" };
  const DECK_LIGHT = { Past:"#e8e0d4", Present:"#d4e0d3", Future:"#d3dce8" };
  const CARD_W = 160, CARD_H = 80;

  function parseCSV(txt) {
    const lines = txt.trim().split(/\r?\n/);
    const headers = splitRow(lines[0]);
    return lines.slice(1).filter(l => l.trim()).map(l => {
      const vals = splitRow(l);
      const o = {};
      headers.forEach((h,i) => { o[h.trim()] = (vals[i]||"").trim(); });
      return o;
    });
  }
  function splitRow(line) {
    const res = []; let cur = "", inQ = false;
    for (let i = 0; i < line.length; i++) {
      const c = line[i];
      if (c === '"') { inQ = !inQ; continue; }
      if (c === ',' && !inQ) { res.push(cur); cur = ""; continue; }
      cur += c;
    }
    res.push(cur);
    return res;
  }
  function f(row, ...keys) {
    for (const k of keys) if (row[k] !== undefined && row[k] !== "") return row[k];
    return "";
  }

  // Load D3
  await new Promise((res, rej) => {
    const s = document.createElement("script");
    s.src = "https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js";
    s.onload = res; s.onerror = rej;
    document.head.appendChild(s);
  });

  // Fetch data
  let questions, connections;
  try {
    const [rQ, rC] = await Promise.all([fetch(Q_URL), fetch(C_URL)]);
    const rawQ = parseCSV(await rQ.text());
    const rawC = parseCSV(await rC.text());

    questions = rawQ.map(r => ({
      id:    f(r,"ID","id"),
      question: f(r,"Question","question"),
      deck:  f(r,"Deck","deck"),
      boc1:  f(r,"Boccagni Dimension 1","boccagni_dimension"),
      boc2:  f(r,"Boccagni Dimension 2","boccagni_dimension_2"),
      type1: f(r,"Research Type 1","research_type"),
      type2: f(r,"Research Type 2","research_type_2"),
      mom1:  f(r,"Research Moment 1","research_moment"),
      mom2:  f(r,"Research Moment 2","research_moment_2"),
      mom3:  f(r,"Research Moment 3","research_moment_3"),
      th1:   f(r,"Theoretical Source 1","theoretical_source"),
      th2:   f(r,"Theoretical Source 2","theoretical_source_2"),
      th3:   f(r,"Theoretical Source 3","theoretical_source_3"),
      keywords: f(r,"Keywords","keywords"),
      desc:  f(r,"Short Description","short_description"),
      conn:  f(r,"Connected Question IDs","contaminated_by_question_ids"),
    })).filter(q => q.id && q.question);

    const edgeSet = new Set();
    connections = rawC.map(r => ({
      source: f(r,"Source ID","source_id"),
      target: f(r,"Target ID","target_id"),
      type:   f(r,"Connection Type","connection_type"),
      note:   f(r,"Connection Note","connection_note"),
    })).filter(c => {
      if (!c.source || !c.target) return false;
      const key = [c.source,c.target].sort().join("||");
      if (edgeSet.has(key)) return false;
      edgeSet.add(key); return true;
    });

  } catch(e) {
    document.getElementById("loading").innerHTML = `<span style="color:#c55;font-size:11px">Could not load data. Check the sheet is published publicly.</span>`;
    return;
  }

  document.getElementById("loading").style.display = "none";

  const qMap = new Map(questions.map(q => [q.id, q]));
  const adj  = new Map(questions.map(q => [q.id, new Set()]));
  connections.forEach(c => {
    if (qMap.has(c.source) && qMap.has(c.target)) {
      adj.get(c.source).add(c.target);
      adj.get(c.target).add(c.source);
    }
  });

  const wrap = document.getElementById("canvas-wrap");
  const W = wrap.clientWidth, H = wrap.clientHeight;

  const svg = d3.select("#canvas")
    .attr("width", W).attr("height", H);

  const g = svg.append("g");

  const zoom = d3.zoom()
    .scaleExtent([0.15, 4])
    .on("zoom", e => g.attr("transform", e.transform));
  svg.call(zoom);

  const connCountMax = Math.max(...questions.map(q => (adj.get(q.id)||new Set()).size), 1);
  function nodeR(d) { return 4 + ((adj.get(d.id)||new Set()).size / connCountMax) * 9; }

  const nodes = questions.map(q => ({ ...q }));
  const links = connections.filter(c => qMap.has(c.source) && qMap.has(c.target))
                            .map(c => ({ ...c }));

  const sim = d3.forceSimulation(nodes)
    .force("link", d3.forceLink(links).id(d => d.id)
      .distance(d => {
        const s = qMap.get(d.source.id||d.source);
        const t = qMap.get(d.target.id||d.target);
        return (s && t && s.deck === t.deck) ? 130 : 210;
      })
      .strength(0.35))
    .force("charge", d3.forceManyBody().strength(-260))
    .force("center", d3.forceCenter(W/2, H/2))
    .force("collide", d3.forceCollide().radius(d => nodeR(d) + CARD_W/2 + 8))
    .force("x", d3.forceX().x(d => d.deck==="Past" ? W*0.24 : d.deck==="Present" ? W*0.5 : W*0.76).strength(0.07))
    .alphaDecay(0.016);

  // Edges
  const linkEls = g.append("g").attr("class","links")
    .selectAll("line").data(links).join("line")
    .attr("stroke", d => {
      const s = qMap.get(d.source.id||d.source);
      const t = qMap.get(d.target.id||d.target);
      return (s && t && s.deck === t.deck) ? DECK_LIGHT[s.deck]||"#ddd" : "#e0ddd8";
    })
    .attr("stroke-width", 0.8)
    .attr("stroke-opacity", 0.45);

  const edgeLabelG = g.append("g").attr("pointer-events","none");

  // Card group
  const cardG = g.append("g").attr("class","cards");

  const cardEls = cardG.selectAll("g").data(nodes).join("g")
    .attr("cursor","pointer")
    .call(d3.drag()
      .on("start",(e,d)=>{ if(!e.active) sim.alphaTarget(0.3).restart(); d.fx=d.x; d.fy=d.y; })
      .on("drag", (e,d)=>{ d.fx=e.x; d.fy=e.y; })
      .on("end",  (e,d)=>{ if(!e.active) sim.alphaTarget(0); d.fx=null; d.fy=null; })
    );

  // Card background
  cardEls.append("rect")
    .attr("x", -CARD_W/2).attr("y", -CARD_H/2)
    .attr("width", CARD_W).attr("height", CARD_H)
    .attr("rx", 2)
    .attr("fill","#ffffff")
    .attr("stroke","#e0e0e0")
    .attr("stroke-width", 0.5);

  // Colored left accent bar
  cardEls.append("rect")
    .attr("x", -CARD_W/2).attr("y", -CARD_H/2)
    .attr("width", 3).attr("height", CARD_H)
    .attr("fill", d => DECK_COLOR[d.deck]||"#999");

  // Deck label
  cardEls.append("text")
    .text(d => d.deck.toUpperCase())
    .attr("x", -CARD_W/2+8).attr("y", -CARD_H/2+11)
    .attr("font-size", 7).attr("font-weight","700")
    .attr("letter-spacing","0.12em")
    .attr("fill", d => DECK_COLOR[d.deck]||"#999");

  // Question text — wrapped manually
  cardEls.each(function(d) {
    const el = d3.select(this);
    const maxLineW = CARD_W - 16;
    const words = d.question.split(" ");
    const lines = [];
    let line = "";
    words.forEach(word => {
      const test = line ? line + " " + word : word;
      if (test.length * 5.0 > maxLineW && line) {
        lines.push(line); line = word;
      } else { line = test; }
    });
    if (line) lines.push(line);
    const maxLines = 3;
    const shown = lines.slice(0, maxLines);
    if (lines.length > maxLines) shown[maxLines-1] = shown[maxLines-1] + "…";

    const textEl = el.append("text")
      .attr("font-size", 9).attr("font-weight","400")
      .attr("fill","#141414");

    shown.forEach((l, i) => {
      textEl.append("tspan")
        .text(l)
        .attr("x", -CARD_W/2+8)
        .attr("y", -CARD_H/2+22 + i*13);
    });

    // ID badge bottom-right
    el.append("text")
      .text(d.id)
      .attr("x", CARD_W/2-6).attr("y", CARD_H/2-7)
      .attr("text-anchor","end")
      .attr("font-size", 7).attr("font-weight","700")
      .attr("letter-spacing","0.08em")
      .attr("fill","#ccc");
  });

  // State
  let activeId = null;
  const activeDeckFilters = new Set();
  let dimFilter = "", typeFilter = "", searchQuery = "";

  function isVisible(d) {
    if (activeDeckFilters.size > 0 && !activeDeckFilters.has(d.deck)) return false;
    if (dimFilter && d.boc1 !== dimFilter && d.boc2 !== dimFilter) return false;
    if (typeFilter && d.type1 !== typeFilter && d.type2 !== typeFilter) return false;
    if (searchQuery) {
      const s = searchQuery.toLowerCase();
      if (!(d.question + d.keywords + (d.desc||"")).toLowerCase().includes(s)) return false;
    }
    return true;
  }

  function getConnected(id) {
    const s = new Set([id]);
    (adj.get(id)||new Set()).forEach(x => s.add(x));
    return s;
  }

  function applyState() {
    const connected = activeId ? getConnected(activeId) : null;
    const visIds = new Set(nodes.filter(d => isVisible(d)).map(d => d.id));

    cardEls.attr("opacity", d => {
      if (!isVisible(d)) return 0.06;
      if (connected && !connected.has(d.id)) return 0.08;
      return 1;
    });
    cardEls.select("rect:first-child")
      .attr("stroke", d => d.id === activeId ? "#141414" : "#e0e0e0")
      .attr("stroke-width", d => d.id === activeId ? 1.5 : 0.5);

    linkEls
      .attr("stroke-opacity", d => {
        const sid = d.source.id||d.source, tid = d.target.id||d.target;
        if (!visIds.has(sid) || !visIds.has(tid)) return 0.03;
        if (!connected) return 0.4;
        return (sid === activeId || tid === activeId) ? 0.9 : 0.04;
      })
      .attr("stroke-width", d => {
        const sid = d.source.id||d.source, tid = d.target.id||d.target;
        if (!connected) return 0.8;
        return (sid === activeId || tid === activeId) ? 2 : 0.5;
      })
      .attr("stroke", d => {
        const sid = d.source.id||d.source, tid = d.target.id||d.target;
        if (connected && (sid === activeId || tid === activeId)) return "#141414";
        const s = qMap.get(sid), t = qMap.get(tid);
        return (s && t && s.deck === t.deck) ? DECK_LIGHT[s.deck]||"#ddd" : "#e0ddd8";
      });

    edgeLabelG.selectAll("*").remove();
    if (activeId) {
      links.forEach(d => {
        const sid = d.source.id||d.source, tid = d.target.id||d.target;
        if (sid !== activeId && tid !== activeId) return;
        if (!d.type) return;
        const sx = d.source.x||0, sy = d.source.y||0;
        const tx = d.target.x||0, ty = d.target.y||0;
        const mx = (sx+tx)/2, my = (sy+ty)/2;
        const lbl = d.type.toUpperCase();
        const bw = lbl.length * 5.8 + 8;
        edgeLabelG.append("rect")
          .attr("x", mx - bw/2).attr("y", my - 8)
          .attr("width", bw).attr("height", 13)
          .attr("rx", 1).attr("fill","#ffffff")
          .attr("stroke","#e0e0e0").attr("stroke-width",0.5);
        edgeLabelG.append("text")
          .text(lbl)
          .attr("x", mx).attr("y", my + 3)
          .attr("text-anchor","middle")
          .attr("font-size", 7).attr("font-weight","700")
          .attr("letter-spacing","0.1em")
          .attr("fill","#141414");
      });
    }

    const vis = nodes.filter(d => isVisible(d)).length;
    document.getElementById("qcount").textContent = vis + " / " + nodes.length;
  }

  // Hover
  cardEls
    .on("mouseenter", (_, d) => {
      if (activeId) return;
      const c = getConnected(d.id);
      cardEls.attr("opacity", n => c.has(n.id) ? 1 : 0.08);
      linkEls
        .attr("stroke-opacity", l => {
          const sid = l.source.id||l.source, tid = l.target.id||l.target;
          return (sid===d.id||tid===d.id) ? 0.9 : 0.04;
        })
        .attr("stroke-width", l => {
          const sid = l.source.id||l.source, tid = l.target.id||l.target;
          return (sid===d.id||tid===d.id) ? 2 : 0.5;
        })
        .attr("stroke", l => {
          const sid = l.source.id||l.source, tid = l.target.id||l.target;
          if (sid===d.id||tid===d.id) return "#141414";
          const s = qMap.get(sid), t = qMap.get(tid);
          return (s&&t&&s.deck===t.deck) ? DECK_LIGHT[s.deck]||"#ddd" : "#e0ddd8";
        });
    })
    .on("mouseleave", () => {
      if (activeId) return;
      applyState();
    })
    .on("click", (e, d) => {
      e.stopPropagation();
      if (activeId === d.id) { activeId = null; closeDrawer(); applyState(); return; }
      activeId = d.id;
      applyState();
      openDrawer(d);
      const t = d3.zoomTransform(svg.node());
      svg.transition().duration(500).call(
        zoom.transform,
        d3.zoomIdentity.translate(W/2 - t.k*d.x, H/2 - t.k*d.y).scale(t.k)
      );
    });

  svg.on("click", () => { activeId = null; closeDrawer(); applyState(); });

  // Drawer
  function openDrawer(d) {
    const color = DECK_COLOR[d.deck]||"#273859";
    document.getElementById("ddeck").textContent = d.deck;
    document.getElementById("ddeck").style.background = color;
    document.getElementById("dq").textContent = d.question;

    const dw = document.getElementById("ddescwrap");
    document.getElementById("ddesc").textContent = d.desc||"";
    dw.style.display = d.desc ? "block" : "none";

    const bocEl = document.getElementById("dboc"); bocEl.innerHTML = "";
    [d.boc1,d.boc2].filter(Boolean).forEach(b => {
      const s = document.createElement("span"); s.className="dtag"; s.textContent=b; bocEl.appendChild(s);
    });

    const kwEl = document.getElementById("dkw"); kwEl.innerHTML = "";
    (d.keywords||"").split(",").map(k=>k.trim()).filter(Boolean).forEach(k => {
      const s = document.createElement("span"); s.className="dkw"; s.textContent=k; kwEl.appendChild(s);
    });

    const momEl = document.getElementById("dmom"); momEl.innerHTML = "";
    [d.mom1,d.mom2,d.mom3].filter(Boolean).forEach(m => {
      const div = document.createElement("div"); div.className="dmi";
      div.innerHTML = `<div class="dmb" style="background:${color}"></div><span>${m}</span>`;
      momEl.appendChild(div);
    });

    const thEl = document.getElementById("dth"); thEl.innerHTML = "";
    [d.th1,d.th2,d.th3].filter(Boolean).forEach(t => {
      const div = document.createElement("div"); div.className="dti"; div.textContent=t; thEl.appendChild(div);
    });

    const connEl = document.getElementById("dconn"); connEl.innerHTML = "";
    (adj.get(d.id)||new Set()).forEach(cid => {
      const nq = qMap.get(cid); if (!nq) return;
      const btn = document.createElement("button");
      btn.className = "dcp"; btn.textContent = cid; btn.title = nq.question;
      btn.style.borderColor = DECK_COLOR[nq.deck]||"#ddd";
      btn.style.color = DECK_COLOR[nq.deck]||"#555";
      btn.onclick = () => {
        activeId = cid; applyState(); openDrawer(nq);
        const nd = nodes.find(n => n.id===cid);
        if (nd) {
          const t = d3.zoomTransform(svg.node());
          svg.transition().duration(400).call(
            zoom.transform,
            d3.zoomIdentity.translate(W/2 - t.k*nd.x, H/2 - t.k*nd.y).scale(t.k)
          );
        }
      };
      connEl.appendChild(btn);
    });

    document.getElementById("drawer").classList.add("open");
  }

  function closeDrawer() {
    document.getElementById("drawer").classList.remove("open");
  }

  document.getElementById("dclose").addEventListener("click", () => {
    activeId = null; closeDrawer(); applyState();
  });

  // Filters
  document.querySelectorAll(".fp[data-deck]").forEach(btn => {
    btn.addEventListener("click", () => {
      const d = btn.dataset.deck;
      const cls = `on-${d.toLowerCase()}`;
      if (activeDeckFilters.has(d)) { activeDeckFilters.delete(d); btn.classList.remove(cls); }
      else { activeDeckFilters.add(d); btn.classList.add(cls); }
      applyState();
    });
  });
  document.getElementById("dimsel").addEventListener("change", e => { dimFilter=e.target.value; applyState(); });
  document.getElementById("typesel").addEventListener("change", e => { typeFilter=e.target.value; applyState(); });
  document.getElementById("search").addEventListener("input", e => { searchQuery=e.target.value.trim(); applyState(); });
  document.getElementById("resetbtn").addEventListener("click", () => {
    activeDeckFilters.clear(); dimFilter=""; typeFilter=""; searchQuery=""; activeId=null;
    document.getElementById("search").value="";
    document.getElementById("dimsel").value="";
    document.getElementById("typesel").value="";
    document.querySelectorAll(".fp[data-deck]").forEach(b => b.className="fp");
    closeDrawer(); applyState();
  });

  // Simulation tick
  sim.on("tick", () => {
    linkEls
      .attr("x1", d => d.source.x).attr("y1", d => d.source.y)
      .attr("x2", d => d.target.x).attr("y2", d => d.target.y);
    cardEls.attr("transform", d => `translate(${d.x},${d.y})`);
    if (activeId) applyState();
  });

  new ResizeObserver(() => {
    const nW = wrap.clientWidth, nH = wrap.clientHeight;
    svg.attr("width", nW).attr("height", nH);
    sim.force("center", d3.forceCenter(nW/2, nH/2)).alpha(0.05).restart();
  }).observe(wrap);

  applyState();
})();
</script>

</Layout>
