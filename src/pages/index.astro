---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Safe Space — Cognitive Orgies',
    year: '2025',
    category: 'Installation',
    slug: 'cognitive-orgies',
    images: [
      'cognitive-orgies/canopy-full.jpeg',
      'cognitive-orgies/canopy-pixelated.jpg',
      'cognitive-orgies/canopy-final-setup.jpeg',
    ],
  },
  {
    title: 'Identity Prosthesis',
    year: '2025',
    category: 'Exhibition',
    slug: 'identity-prosthesis',
    images: [null, null, null],
  },
  {
    title: 'Espejito Espejito — Mayrit Bienal 2024',
    year: '2024',
    category: 'Curation',
    slug: null,
    images: [null, null, null],
  },
  {
    title: 'Revisiting Tithonus — Medialab Matadero',
    year: '2024',
    category: 'Research',
    slug: null,
    images: [null, null, null],
  },
  {
    title: 'Staging The Planetary',
    year: '2023',
    category: 'Performance',
    slug: null,
    images: [null, null, null],
  },
];
---

<Layout title="Madlen von Wulffen" description="Design, research & spatial practice — Belonging / Urban Sociology / Living Forms">

  <!-- HERO -->
  <section class="hero animate-in">
    <h1 class="hero-text">
      Design, research &amp;<br /><em>spatial practice</em>
    </h1>
    <p class="hero-subtitle">Belonging &nbsp;/&nbsp; Urban Sociology &nbsp;/&nbsp; Living Forms</p>
  </section>

  <!-- PROJECTS TABLE -->
  <section class="projects-section">
    <div class="table-header">
      <span>Project</span>
      <span>Year</span>
      <span>Featured Images</span>
      <span>Category</span>
    </div>

    {projects.map((project, i) => (
      <a
        href={project.slug ? `${import.meta.env.BASE_URL}projects/${project.slug}` : '#'}
        class="project-row"
        style={`animation-delay: ${0.1 + i * 0.08}s`}
      >
        <div class="project-title">{project.title}</div>
        <div class="project-year">{project.year}</div>
        <div class="project-images">
          {project.images.map((img) => (
            <div class="img-placeholder">
              {img && <img src={`${import.meta.env.BASE_URL}images/${img}`} alt="" />}
            </div>
          ))}
        </div>
        <div class="project-tag">{project.category}</div>
      </a>
    ))}
  </section>

</Layout>

<style>
  /* ── HERO ── */
  .hero {
    padding: 7rem 2.5rem 5rem;
    border-bottom: 1px solid var(--black);
  }

  .hero-text {
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 820px;
  }

  .hero-text em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-subtitle {
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
  }

  /* ── PROJECTS TABLE ── */
  .projects-section {
    padding: 0 2.5rem;
  }

  .table-header {
    display: grid;
    grid-template-columns: 2fr 0.6fr 2.8fr 0.8fr;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--black);
    animation: fadeUp 0.5s 0.35s ease both;
  }

  .table-header span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
  }

  .project-row {
    display: grid;
    grid-template-columns: 2fr 0.6fr 2.8fr 0.8fr;
    gap: 1rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--light-gray);
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
    animation: fadeUp 0.5s ease both;
    cursor: ne-resize;
  }

  .project-row:hover .project-title {
    color: var(--accent);
  }

  .project-title {
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    transition: color 0.15s ease;
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--gray);
    letter-spacing: 0.03em;
    align-self: flex-start;
    padding-top: 0.2rem;
  }

  .project-images {
    display: flex;
    gap: 6px;
  }

  .img-placeholder {
    width: 90px;
    height: 62px;
    background: var(--light-gray);
    flex-shrink: 0;
    overflow: hidden;
  }

  .img-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    border: 1px solid var(--light-gray);
    padding: 0.3rem 0.55rem;
    align-self: flex-start;
    white-space: nowrap;
  }
</style>