---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Madlen von Wulffen" description="Design, research & spatial practice">
  <div class="page">
    <div class="description-block">
      <p>This is an exploration of the home in the realms of <u>ecological thinking</u>, <u>circular cities</u>, <u>systemic innovation</u>, <u>future living</u> and <u>social transformation</u>. This is a space for experimentation and imagination on how we inhabit our homes.</p>
    </div>
    <div class="home-wordmark">HOME</div>
  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: 2.8rem;
  }

  .description-block {
    padding: 2.4rem 2.6rem 0;
    max-width: 520px;
    margin-left: auto;
    margin-right: 2.6rem;
  }

  .description-block p {
    font-size: 0.94rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink);
    letter-spacing: 0.01em;
  }

  .description-block u {
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }

  .home-wordmark {
    font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
    font-weight: 900;
    font-size: 23.5vw;
    line-height: 0.85;
    color: #141414;
    white-space: nowrap;
    display: block;
    width: 100vw;
    margin-left: calc(-1 * var(--page-padding, 0px));
    letter-spacing: -0.02em;
    overflow: hidden;
  }
</style>
