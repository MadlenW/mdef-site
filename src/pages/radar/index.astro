---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Home Foresight Radar · Madlen von Wulffen" description="An interactive foresight radar mapping signals of change in the future of home.">
  <div id="radar-page">
    <div id="toolbar">
      <div id="toolbar-left">
        <span class="toolbar-title">Home Foresight Radar</span>
      </div>
      <div id="filters">
        <button class="pill active" data-filter="all">All</button>
        <button class="pill" data-filter="Technological">Technological</button>
        <button class="pill" data-filter="Economical">Economical</button>
        <button class="pill" data-filter="Socio-Demographic">Socio-Demographic</button>
        <button class="pill" data-filter="Governance">Governance</button>
        <button class="pill" data-filter="Environmental">Environmental</button>
        <button class="pill" data-filter="Values">Values</button>
      </div>
      <button id="add-btn">+ Add Signal</button>
    </div>

    <div id="wrap">
      <svg id="svg" viewBox="0 0 900 940" xmlns="http://www.w3.org/2000/svg"></svg>
      <div id="sp">
        <span class="sx" id="sp-close">×</span>
        <div class="ss"></div>
        <div class="st"></div>
        <div class="sr"></div>
        <div class="sd2"></div>
      </div>
    </div>

    <!-- Add Signal Modal -->
    <div id="modal-bg">
      <div id="modal">
        <h2>Add a Signal</h2>
        <label>Title<input id="m-title" type="text" placeholder="e.g. Rental Algorithims"/></label>
        <label>Description<textarea id="m-desc" placeholder="What is this signal about?"></textarea></label>
        <label>Sector
          <select id="m-sector">
            <option>Technological</option>
            <option>Economical</option>
            <option>Socio-Demographic</option>
            <option>Governance</option>
            <option>Environmental</option>
            <option>Values</option>
          </select>
        </label>
        <label>Ring
          <select id="m-ring">
            <option>Body</option>
            <option>Domestic Space</option>
            <option>Social Systems</option>
            <option>Ecosystems</option>
            <option>Planetary Boundaries</option>
          </select>
        </label>
        <div id="modal-btns">
          <button id="modal-cancel">Cancel</button>
          <button id="modal-add">Add Signal</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  #radar-page {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 56px);
    overflow: hidden;
  }

  #toolbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.8rem 2rem;
    border-bottom: 0.5px solid #e0e0e0;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .toolbar-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #111;
    margin-right: 0.5rem;
    white-space: nowrap;
  }

  #filters {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    flex: 1;
  }

  .pill {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 0.5px solid #bbb;
    border-radius: 2px;
    background: transparent;
    color: #888;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.12s;
  }
  .pill:hover { color: #111; border-color: #111; }
  .pill.active { background: #111; color: #fff; border-color: #111; }

  #add-btn {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 0.5px solid #111;
    border-radius: 2px;
    background: transparent;
    color: #111;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: all 0.12s;
  }
  #add-btn:hover { background: #111; color: #fff; }

  #wrap {
    position: relative;
    flex: 1;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #wrap svg {
    height: 100%;
    width: auto;
    max-height: 100%;
  }

  #sp {
    position: absolute;
    background: white;
    border: 0.5px solid #ddd;
    border-radius: 10px;
    padding: 14px 16px;
    width: 220px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 10;
    box-shadow: 0 4px 18px rgba(0,0,0,0.09);
    font-family: inherit;
  }
  #sp.on { opacity: 1; pointer-events: auto; }
  #sp .ss { font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: #aaa; margin-bottom: 3px; }
  #sp .st { font-size: 13px; font-weight: 600; color: #111; margin-bottom: 3px; line-height: 1.3; }
  #sp .sr { font-size: 11px; color: #888; margin-bottom: 8px; }
  #sp .sd2 { font-size: 11px; color: #555; line-height: 1.6; border-top: 0.5px solid #eee; padding-top: 8px; }
  #sp .sx { position: absolute; top: 8px; right: 11px; cursor: pointer; font-size: 16px; opacity: 0.3; pointer-events: auto; }
  #sp .dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 5px; vertical-align: middle; }

  /* Modal */
  #modal-bg {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }
  #modal-bg.on { display: flex; }
  #modal {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    width: 400px;
    max-width: 90vw;
    box-shadow: 0 8px 40px rgba(0,0,0,0.12);
  }
  #modal h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1.4rem;
    letter-spacing: -0.01em;
  }
  #modal label {
    display: block;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 1rem;
  }
  #modal input, #modal textarea, #modal select {
    display: block;
    width: 100%;
    margin-top: 4px;
    padding: 8px 10px;
    border: 0.5px solid #ddd;
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
    color: #111;
    outline: none;
  }
  #modal textarea { height: 70px; resize: none; }
  #modal-btns {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
    margin-top: 1.4rem;
  }
  #modal-cancel {
    padding: 7px 16px;
    border: 0.5px solid #ddd;
    border-radius: 6px;
    background: white;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: inherit;
  }
  #modal-add {
    padding: 7px 16px;
    border: none;
    border-radius: 6px;
    background: #111;
    color: white;
    font-size: 0.8rem;
    cursor: pointer;
    font-family: inherit;
  }
</style>

<script>
const NS = 'http://www.w3.org/2000/svg';
const svg = document.getElementById('svg');
const cx = 450, cy = 450;

function el(tag, attrs, parent) {
  const e = document.createElementNS(NS, tag);
  for (const [k,v] of Object.entries(attrs)) e.setAttribute(k, v);
  if (parent) parent.appendChild(e);
  return e;
}
function txt(content, attrs, parent) {
  const e = el('text', attrs, parent);
  e.textContent = content;
  return e;
}

el('rect', {width:900, height:940, fill:'white'}, svg);
[300,225,150,75].forEach((r,i) => {
  el('circle', {cx,cy,r, fill:['#f7f7f7','#efefef','#e5e5e5','#dbdbdb'][i], stroke:'#ccc','stroke-width':'0.75'}, svg);
});
for (let i=0;i<6;i++){
  const a=(i*60-90)*Math.PI/180;
  el('line',{x1:cx,y1:cy,x2:cx+360*Math.cos(a),y2:cy+360*Math.sin(a),stroke:'#ccc','stroke-width':'0.5'},svg);
}
['PLANETARY BOUNDARIES','ECOSYSTEMS','SOCIAL SYSTEMS','DOMESTIC SPACE','BODY'].forEach((l,i)=>{
  txt(l,{x:458,y:[155,230,305,378,428][i],'font-size':'9',fill:'#bbb','font-family':'sans-serif','letter-spacing':'1'},svg);
});

const labelR = 338, charDeg = 4.0;
[
  {label:'TECHNOLOGICAL',     bisector:30},
  {label:'ECONOMICAL',        bisector:90},
  {label:'SOCIO-DEMOGRAPHIC', bisector:150},
  {label:'GOVERNANCE',        bisector:210},
  {label:'ENVIRONMENTAL',     bisector:270},
  {label:'VALUES',            bisector:330},
].forEach(({label,bisector}) => {
  const chars = label.split('');
  const totalSpan = (chars.length-1)*charDeg;
  chars.forEach((ch,i) => {
    const angleDeg = bisector - totalSpan/2 + i*charDeg;
    const angleRad = (angleDeg-90)*Math.PI/180;
    const x = cx + labelR*Math.cos(angleRad);
    const y = cy + labelR*Math.sin(angleRad);
    txt(ch,{x,y,'font-size':'13','font-weight':'700','font-family':'sans-serif',fill:'#222','text-anchor':'middle','dominant-baseline':'middle',transform:`rotate(${angleDeg},${x},${y})`},svg);
  });
});

el('circle',{cx,cy,r:20,fill:'white',stroke:'#ccc','stroke-width':'0.75'},svg);
txt('BODY',{x:cx,y:cy+1,'font-size':'8',fill:'#aaa','font-family':'sans-serif','text-anchor':'middle','dominant-baseline':'middle'},svg);

function pos(deg,r){ const rad=deg*Math.PI/180; return [cx+r*Math.sin(rad),cy-r*Math.cos(rad)]; }

const ringColors = {'Body':'#e879a0','Domestic Space':'#a78bfa','Social Systems':'#60a5fa','Ecosystems':'#34d399','Planetary Boundaries':'#34d399'};

let signals = [
  {title:'Home as Surveillance Site', sector:'Technological',    ring:'Social Systems',       deg:30,  r:187, desc:'Smart home data extraction by platforms, employers and insurers normalises the home as a site of continuous monitoring.'},
  {title:'Work-Home Blur',            sector:'Technological',    ring:'Domestic Space',       deg:22,  r:112, desc:'Permanent collapse of domestic and professional boundaries driven by remote work infrastructure embedded in the home.'},
  {title:'Platformed Housing',        sector:'Economical',       ring:'Social Systems',       deg:90,  r:187, desc:'Renting mediated entirely by algorithmic platforms that extract data, set prices dynamically, and remove landlord accountability.'},
  {title:'Micro-Living Densification',sector:'Economical',       ring:'Ecosystems',           deg:98,  r:262, desc:'Sub-30m² units becoming the urban housing norm as land prices concentrate housing into ever-smaller footprints.'},
  {title:'Housing Financialization',  sector:'Economical',       ring:'Planetary Boundaries', deg:82,  r:287, desc:'Global capital treating housing as an asset class, structurally decoupling shelter from local wages and social need.'},
  {title:'Co-Living as Default',      sector:'Socio-Demographic',ring:'Domestic Space',       deg:155, r:112, desc:'Shared housing normalised for economic and social reasons — not a lifestyle choice but a structural condition of precarious adulthood.'},
  {title:'Chosen Family Clusters',    sector:'Socio-Demographic',ring:'Body',                 deg:145, r:42,  desc:'Non-biological household formations becoming the primary social unit — care networks built from friendship, not kinship.'},
  {title:'Precarious Homemaking',     sector:'Governance',       ring:'Planetary Boundaries', deg:212, r:275, desc:'Rising structural unaffordability forcing nomadic dwelling — homemaking as ongoing improvisation under conditions of systemic instability.'},
  {title:'Net-Zero Home Mandate',     sector:'Environmental',    ring:'Social Systems',       deg:270, r:187, desc:'Ecological performance requirements embedded into housing regulation — homes as energy infrastructure rather than private property.'},
  {title:'Biophilic Home Design',     sector:'Values',           ring:'Domestic Space',       deg:330, r:112, desc:'Nature integration as mental health infrastructure — growing normative expectation that homes provide living materials, light, and ecological connection.'},
];

const dotGroup = el('g', {id:'dots'}, svg);

function renderSignals(filter='all') {
  dotGroup.innerHTML = '';
  signals.forEach(s => {
    if (filter !== 'all' && s.sector !== filter) return;
    const color = ringColors[s.ring] || '#999';
    const [x,y] = pos(s.deg, s.r);
    const c = el('circle',{cx:x,cy:y,r:7,fill:color,stroke:'white','stroke-width':'1.5',class:'sd',style:'cursor:pointer'},dotGroup);
    Object.entries({title:s.title,sector:s.sector,ring:s.ring,color,desc:s.desc}).forEach(([k,v])=>c.dataset[k]=v);
    c.addEventListener('click', handleDotClick);
  });
}

renderSignals();

// Legend
let lx=220;
[{color:'#e879a0',label:'Body'},{color:'#a78bfa',label:'Domestic'},{color:'#60a5fa',label:'Social'},{color:'#34d399',label:'Ecosystems / Planetary'}].forEach(({color,label})=>{
  el('circle',{cx:lx,cy:905,r:5,fill:color},svg);
  txt(label,{x:lx+9,y:909,'font-size':'10',fill:'#888','font-family':'sans-serif'},svg);
  lx+=label.length*7+28;
});

// Popup
const sp = document.getElementById('sp');
const wrap = document.getElementById('wrap');

function handleDotClick(e) {
  const svgRect = svg.getBoundingClientRect();
  const wrapRect = wrap.getBoundingClientRect();
  const scaleX = svgRect.width / 900;
  const scaleY = svgRect.height / 940;
  const svgOffsetX = svgRect.left - wrapRect.left;
  const svgOffsetY = svgRect.top - wrapRect.top;
  const x = parseFloat(this.getAttribute('cx')) * scaleX + svgOffsetX;
  const y = parseFloat(this.getAttribute('cy')) * scaleY + svgOffsetY;
  sp.querySelector('.ss').textContent = this.dataset.sector;
  sp.querySelector('.st').innerHTML = '<span class="dot" style="background:'+this.dataset.color+'"></span>'+this.dataset.title;
  sp.querySelector('.sr').textContent = this.dataset.ring;
  sp.querySelector('.sd2').textContent = this.dataset.desc;
  let left = x+14, top = y-20;
  if (left+230 > wrapRect.width) left = x-234;
  if (top+170 > wrapRect.height) top = y-165;
  if (top < 0) top = 4;
  sp.style.left = left+'px'; sp.style.top = top+'px';
  sp.classList.add('on'); e.stopPropagation();
}

document.getElementById('sp-close').addEventListener('click', () => sp.classList.remove('on'));
wrap.addEventListener('click', () => sp.classList.remove('on'));

// Filters
document.querySelectorAll('.pill').forEach(p => {
  p.addEventListener('click', function() {
    document.querySelectorAll('.pill').forEach(x => x.classList.remove('active'));
    this.classList.add('active');
    renderSignals(this.dataset.filter);
  });
});

// Add signal modal
const modalBg = document.getElementById('modal-bg');
document.getElementById('add-btn').addEventListener('click', () => modalBg.classList.add('on'));
document.getElementById('modal-cancel').addEventListener('click', () => modalBg.classList.remove('on'));
modalBg.addEventListener('click', e => { if(e.target===modalBg) modalBg.classList.remove('on'); });

const sectorBisectors = {
  'Technological':30,'Economical':90,'Socio-Demographic':150,
  'Governance':210,'Environmental':270,'Values':330
};
const ringRadii = {
  'Body':42,'Domestic Space':112,'Social Systems':187,
  'Ecosystems':262,'Planetary Boundaries':287
};

document.getElementById('modal-add').addEventListener('click', () => {
  const title = document.getElementById('m-title').value.trim();
  const desc = document.getElementById('m-desc').value.trim();
  const sector = document.getElementById('m-sector').value;
  const ring = document.getElementById('m-ring').value;
  if (!title) return;
  const bisector = sectorBisectors[sector];
  const r = ringRadii[ring];
  const jitter = (Math.random()-0.5)*18;
  signals.push({title, sector, ring, deg: bisector+jitter, r: r+(Math.random()-0.5)*20, desc: desc||'No description.'});
  const activeFilter = document.querySelector('.pill.active').dataset.filter;
  renderSignals(activeFilter);
  modalBg.classList.remove('on');
  document.getElementById('m-title').value = '';
  document.getElementById('m-desc').value = '';
});
</script>
