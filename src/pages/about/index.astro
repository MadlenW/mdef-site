---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="About — Madlen von Wulffen" description="About Madlen von Wulffen">
  <div class="page">

    <div class="hero">
      <div class="photo-wrap">
        <img src={`${base}images/MnonameMoun.png`} alt="Madlen von Wulffen" />
      </div>
      <div class="about-word">ABOUT</div>
    </div>

    <div class="about-body">
      <div class="bio-col">
        <p>I am Madlen von Wulffen, a designer and researcher working at the intersection of spatial practice, urban sociology, and the politics of living.</p>
        <p>My work examines how the spaces we inhabit shape — and are shaped by — questions of belonging, identity, and collective life. Based between Berlin and Madrid, I work across installation, curation, and research.</p>
        <p>I am interested in the home not as a fixed category but as a site of negotiation — between bodies, histories, and futures.</p>
      </div>

      <div class="contact-col">
        <span class="section-label">Contact</span>
        <div class="contact-row">
          <span class="c-label">Email</span>
          <a class="c-val" href="mailto:hello@madlenvonwulffen.com">hello@madlenvonwulffen.com</a>
        </div>
        <div class="contact-row">
          <span class="c-label">Instagram</span>
          <a class="c-val" href="https://instagram.com/madlenvonwulffen" target="_blank">@madlenvonwulffen</a>
        </div>
        <div class="contact-row">
          <span class="c-label">Based</span>
          <span class="c-val">Berlin / Madrid</span>
        </div>
        <div class="contact-row">
          <span class="c-label">Languages</span>
          <span class="c-val">German, English, Spanish</span>
        </div>
        <a class="cv-link" href={`${base}cv.pdf`} target="_blank">Download CV →</a>
      </div>
    </div>

  </div>
</Layout>

<style>
  .page { padding-top: 2.8rem; }

  /* HERO */
  .hero {
    position: relative;
    height: 480px;
    overflow: visible;
  }

  .photo-wrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 42%;
    height: 100%;
    z-index: 2;
  }
  .photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .about-word {
    position: absolute;
    bottom: -0.1em;
    left: 0;
    right: 0;
    z-index: 3;
    font-family: Arial, 'Helvetica Neue', Helvetica, sans-serif;
    font-weight: 900;
    font-size: clamp(100px, 16vw, 180px);
    line-height: 0.85;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  /* BODY */
  .about-body {
    padding: 3.5rem 2.6rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .bio-col p {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.6;
    color: #222;
    max-width: 52ch;
    margin-bottom: 1.4em;
  }
  .bio-col p:last-child { margin-bottom: 0; }

  .contact-col { padding-top: 0.1rem; }

  .section-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 1.6rem;
  }

  .contact-row { margin-bottom: 1.2rem; }

  .c-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 0.25rem;
  }

  .c-val {
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--ink);
    text-decoration: none;
    line-height: 1.4;
    display: block;
    transition: opacity 0.15s;
  }
  a.c-val:hover { opacity: 0.5; }

  .cv-link {
    display: inline-block;
    margin-top: 1.8rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 0.2rem;
    transition: opacity 0.15s;
  }
  .cv-link:hover { opacity: 0.5; }
</style>
