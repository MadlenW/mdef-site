---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About — Madlen von Wulffen" description="About Madlen von Wulffen.">
  <Header slot="header" />

  <!-- Main About layout -->
  <section class="about-grid">
    <!-- LEFT: portrait + statement overlay -->
    <section class="about-left">
      <div class="about-statement">
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer in risus at nunc
          elementum, gravida enim ac, vehicula arcu. Nunc condimentum leo eget diam viverra,
          vitae maximus lacus consequat. Sed non ultrices arcu. Vestibulum ante ipsum primis
          in faucibus orci luctus et ultrices posuere cubilia curae.
        </p>
      </div>

      <figure class="about-portrait">
        <img src={base + 'images/MnonameMoun.png'} alt="Portrait of Madlen von Wulffen" />
      </figure>
    </section>

    <!-- RIGHT: CV blocks -->
    <section class="about-right">
      <div class="cv-section">
        <h2>Education</h2>
        <ul class="cv-list">
          <li>
            <strong>Institute for Advanced Architecture + ELISAVA, Barcelona</strong><br />
            <span>09/2025–07/2026 · Design for Emergent Futures</span>
          </li>
          <li>
            <strong>Zeppelin University, Friedrichshafen</strong><br />
            <span>09/2019–09/2023 · BA Sociology, Politics &amp; Economics (GPA 1.5)</span><br />
            <span>Thesis: “Interconnected Ecological Logic: A Concept of Order for New Housing Forms”</span>
          </li>
          <li>
            <strong>Copenhagen Business School</strong><br />
            <span>01/2022–06/2022 · Erasmus · Digital Management &amp; Sustainable Business</span>
          </li>
          <li>
            <strong>Arndt Gymnasium, Berlin</strong><br />
            <span>08/2016–07/2018 · Abitur (1.5) · Year abroad in Harrisburg, USA</span>
          </li>
        </ul>
      </div>

      <div class="cv-section">
        <h2>Experience</h2>
        <ul class="cv-list">
          <li>
            <strong>Arup GmbH, Berlin — Industrial Trainee (Cities)</strong><br />
            <span>01/2025–05/2025</span><br />
            <span>Strategies for mobility, air quality &amp; climate adaptation; circular economy &amp; regenerative research.</span>
          </li>
          <li>
            <strong>Wunderflats GmbH, Berlin — Real Estate Operations Intern</strong><br />
            <span>09/2024–12/2024</span><br />
            <span>Property &amp; tenant management; workflow streamlining; market dynamics and trends.</span>
          </li>
          <li>
            <strong>Technologiestiftung Berlin — Intern (Event &amp; Project Management)</strong><br />
            <span>06/2024–08/2024</span><br />
            <span>CityLAB Summer Conference implementation &amp; assistance.</span>
          </li>
          <li>
            <strong>Ökoplan Engineering Consultations — Intern (Urban Design)</strong><br />
            <span>01/2024–06/2024</span><br />
            <span>Context-specific masterplanning; research assistance.</span>
          </li>
          <li>
            <strong>Büro grauwert — Research Assistant</strong><br />
            <span>10/2023–12/2023</span><br />
            <span>Report on inclusive urban design (Design for All) for Bahnhofs.Quartier.Bieberich.</span>
          </li>
          <li>
            <strong>Berlin Global Advisors — Intern (Geopolitics &amp; Government Affairs)</strong><br />
            <span>06/2020–08/2020</span><br />
            <span>Briefings, issue mappings, stakeholder analyses on geopolitical initiatives.</span>
          </li>
          <li>
            <strong>Scope SE &amp; Co. KGaA — Intern (Media &amp; Communications)</strong><br />
            <span>05/2017–07/2017</span><br />
            <span>Analysis support: “Open-ended real estate funds — market study and ratings 2017”; ESG &amp; ECAF research.</span>
          </li>
        </ul>
      </div>

      <div class="cv-section">
        <h2>Engagement</h2>
        <ul class="cv-list">
          <li>
            <strong>Female Founders Night — General Management</strong><br />
            <span>11/2022–01/2023 · Fundraising 10,000€ · Built Europe-wide partner network.</span>
          </li>
          <li>
            <strong>Technologiestiftung / CityLAB</strong><br />
            <span>Community &amp; event support (see above).</span>
          </li>
          <li>
            <strong>Pulse of Europe — Volunteer</strong><br />
            <span>05/2017–10/2018 · Rallies &amp; HausParlamente dialogue format.</span>
          </li>
        </ul>
      </div>

      <div class="cv-section columns">
        <div>
          <h2>Skills</h2>
          <ul class="cv-list compact">
            <li>Systems thinking, writing &amp; storytelling</li>
            <li>AutoCAD, InDesign, Photoshop</li>
            <li>Microsoft Office</li>
          </ul>
        </div>
        <div>
          <h2>Languages</h2>
          <ul class="cv-list compact">
            <li>German — native</li>
            <li>English — professional</li>
            <li>Spanish — B2</li>
          </ul>
        </div>
        <div>
          <h2>Interests</h2>
          <ul class="cv-list compact">
            <li>Urban &amp; Social Design</li>
            <li>Literature</li>
            <li>Cooking &amp; Hospitality</li>
            <li>Start-up Ecosystem</li>
          </ul>
        </div>
      </div>
    </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  :root {
    --about-grid-line: #dcdcdc;
  }

  /* Whole about layout */
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.6fr);
    column-gap: clamp(24px, 4vw, 48px);
    padding: clamp(24px, 5vw, 48px);
    border-top: 1px solid var(--about-grid-line);
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      row-gap: 40px;
    }
  }

  /* LEFT SIDE */
  .about-left {
    position: relative;
  }

  .about-portrait {
    margin: 0;
  }

  .about-portrait img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .about-statement {
    position: absolute;
    left: 10%;
    bottom: 8%;
    max-width: 75%;
    background: #ffffff;
    border: 1px solid var(--about-grid-line);
    padding: 16px 20px;
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .about-statement {
      position: static;
      max-width: none;
      margin-bottom: 16px;
    }
  }

  /* RIGHT SIDE: CV */
  .about-right {
    display: flex;
    flex-direction: column;
    gap: 32px;
    font-size: 14px;
    line-height: 1.6;
  }

  .cv-section h2 {
    font-family: "Monument Grotesk", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 8px;
  }

  .cv-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cv-list li + li {
    margin-top: 10px;
  }

  .cv-list span {
    display: block;
  }

  .cv-section.columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: 24px;
    row-gap: 16px;
  }

  .cv-section.columns h2 {
    margin-bottom: 6px;
  }

  .cv-list.compact li + li {
    margin-top: 4px;
  }

  @media (max-width: 900px) {
    .cv-section.columns {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .cv-section.columns {
      grid-template-columns: 1fr;
    }
  }
</style>
