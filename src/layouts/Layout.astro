---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Madlen von Wulffen',
  description = 'Design, research & spatial practice',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}images/favicon-house.png`} />

  </head>
  <body style={`cursor: url(${base}images/favicon-house.png) 4 4, auto;`}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>

<style>
  main {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - var(--header-height));
    padding: 0;
    margin: 0;
  }
</style>
</html>